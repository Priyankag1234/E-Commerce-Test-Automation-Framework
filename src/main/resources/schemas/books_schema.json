{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Books API Response Schema",
  "description": "JSON Schema for the DemoQA BookStore GET /Books response",
  "type": "object",
  "required": ["books"],
  "properties": {
    "books": {
      "type": "array",
      "description": "List of available books",
      "items": {
        "type": "object",
        "required": ["isbn", "title", "author"],
        "properties": {
          "isbn": {
            "type": "string",
            "description": "International Standard Book Number"
          },
          "title": {
            "type": "string",
            "description": "Book title"
          },
          "subTitle": {
            "type": "string",
            "description": "Book subtitle (may be empty)"
          },
          "author": {
            "type": "string",
            "description": "Author name(s)"
          },
          "publish_date": {
            "type": "string",
            "description": "Publication date"
          },
          "publisher": {
            "type": "string",
            "description": "Publishing company"
          },
          "pages": {
            "type": "integer",
            "description": "Number of pages",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "description": "Book description"
          },
          "website": {
            "type": "string",
            "description": "Related website URL"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
